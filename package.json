{
    "name": "receiptv",
    "version": "1.0.0",
    "scripts": {
        "server": "cd server && npm start",
        "client": "cd client && npm run dev",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "install-all": "cd server && npm install && cd ../client && npm install"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}