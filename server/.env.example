PORT=5000
DATABASE_URL=postgresql://postgres:root@localhost:5434/receiptv
JWT_SECRET=sua_chave_jwt_aqui
GROQ_API_KEY=sua_chave_groq_aqui
NODE_ENV=development

# URL de conexão ao Supabase para persistência de logs (opcional).
# Se não definida, logs são gravados apenas em arquivo/console.
# Obter em: Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_LOG_URL=postgresql://postgres:[senha]@[host]:5432/postgres
